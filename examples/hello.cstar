func calculate_neuron -> int {
    let weights: [int] = [2, 4, 6, 8, 10]
    let inputs: [int] = [1, 3, 5, 7, 9]
    let sum: int = 0
    let i: int = 0
    
    while i < 5 {
        sum = sum + weights[i] * inputs[i]
        i = i + 1
    }
    
    return sum
}

let ai_result: int = calculate_neuron
print(ai_result)
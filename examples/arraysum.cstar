# Create a small dataset of 'weights'
let weights: [float] = [0.5, 1.2, 0.8, 2.5]

func sum_data(data: [float]) -> float {
    let total: float = 0.0
    let i: int = 0
    
    while i < 4 {
        total = total + data[i]
        i = i + 1
    }
    
    return total
}

let result: float = sum_data(weights)
print(result)